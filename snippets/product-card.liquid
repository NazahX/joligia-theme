{% liquid
  assign card_product = product
  assign show_vendor = show_vendor | default: false
  assign show_secondary = show_secondary | default: true
  assign image_ratio = image_ratio | default: 'portrait'
%}

{% if card_product != blank %}
  <article class="product-card">
    <a class="product-card__media product-card__media--{{ image_ratio }}" href="{{ card_product.url }}">
      {% if card_product.featured_media %}
        {% render 'responsive-image',
          image: card_product.featured_media.preview_image,
          class: 'product-card__image product-card__image--primary',
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
          width: 900,
          loading: 'lazy'
        %}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image product-card__image--primary' }}
      {% endif %}

      {% if show_secondary and card_product.media.size > 1 %}
        {% assign secondary_media = card_product.media[1].preview_image %}
        {% render 'responsive-image',
          image: secondary_media,
          class: 'product-card__image product-card__image--secondary',
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
          width: 900,
          loading: 'lazy'
        %}
      {% endif %}
    </a>

    <div class="product-card__content">
      {% if show_vendor %}
        <p class="eyebrow">{{ card_product.vendor }}</p>
      {% endif %}
      <h3 class="product-card__title"><a href="{{ card_product.url }}">{{ card_product.title }}</a></h3>
      {% render 'price', product_or_variant: card_product %}
    </div>
  </article>
{% endif %}
