{% if collection != blank %}
  <article class="product-card">
    <a class="product-card__media product-card__media--portrait" href="{{ collection.url }}">
      {% if collection.featured_image %}
        {% render 'responsive-image',
          image: collection.featured_image,
          class: 'product-card__image product-card__image--primary',
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
          width: 900,
          loading: 'lazy'
        %}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg product-card__image product-card__image--primary' }}
      {% endif %}
    </a>
    <div class="product-card__content">
      <h3 class="product-card__title"><a href="{{ collection.url }}">{{ collection.title }}</a></h3>
      <p class="cart-item__meta">{{ collection.all_products_count }} pieces</p>
    </div>
  </article>
{% endif %}
