{% liquid
  assign icon_name = icon | default: 'arrow'
%}
<span class="icon icon-{{ icon_name }}" aria-hidden="true">
  {% case icon_name %}
    {% when 'menu' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'close' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'search' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M16 16l4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'bag' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M7 9h10l-.8 10.2a2 2 0 0 1-2 1.8H9.8a2 2 0 0 1-2-1.8L7 9Z" stroke="currentColor" stroke-width="1.4"/>
        <path d="M9 9V7.8a3 3 0 0 1 6 0V9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'account' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.4"/>
        <path d="M5.5 19a6.5 6.5 0 0 1 13 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'arrow' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    {% when 'chevron-down' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    {% when 'plus' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'minus' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M5 12h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    {% when 'instagram' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <rect x="4.5" y="4.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.4"/>
        <circle cx="12" cy="12" r="3.6" stroke="currentColor" stroke-width="1.4"/>
        <circle cx="17.1" cy="6.9" r="0.8" fill="currentColor"/>
      </svg>
    {% when 'pinterest' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M12 4.5a7.5 7.5 0 0 0-2.7 14.5l.7-2.7c-.4-.9-.7-2-.7-3.1a4.6 4.6 0 1 1 8.4 2.6c-.8 1.1-2 1.8-3.1 1.8-.9 0-1.6-.5-1.6-1.5 0-.9.6-2.1 1-3.6.4-1.5-.6-2.3-1.7-2.3-1.4 0-2.5 1.4-2.5 3.2 0 1.2.4 2 .4 2l-1.5 6a7.5 7.5 0 1 0 1.6-14.9Z" fill="currentColor"/>
      </svg>
    {% when 'tiktok' %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <path d="M14 4c.2 1.5 1.4 3.1 3 3.7V10a6.8 6.8 0 0 1-3-1V14a5 5 0 1 1-5-5h.3v2.5H9a2.5 2.5 0 1 0 2.5 2.5V4H14Z" fill="currentColor"/>
      </svg>
    {% else %}
      <svg viewBox="0 0 24 24" fill="none" focusable="false">
        <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.4"/>
      </svg>
  {% endcase %}
</span>
