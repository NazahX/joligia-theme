<section class="page-hero">
  <div class="content-width page-hero__inner">
    <p class="eyebrow">{{ section.settings.overline }}</p>
    <h1>{{ page.title }}</h1>
    {% if page.content != blank %}
      <div class="page-hero__text rte">{{ page.content }}</div>
    {% elsif section.settings.intro != blank %}
      <div class="page-hero__text rte">{{ section.settings.intro }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "Inside the brand",
      "label": "Overline"
    },
    {
      "type": "richtext",
      "id": "intro",
      "default": "<p>Add a concise introduction here if the page body is empty. Otherwise the page content from Shopify will render automatically.</p>",
      "label": "Fallback intro"
    }
  ]
}
{% endschema %}
