<section class="collection-hero">
  <div class="content-width collection-hero__inner">
    <p class="eyebrow">{{ section.settings.overline }}</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="collection-hero__text rte">{{ collection.description }}</div>
    {% elsif section.settings.fallback_text != blank %}
      <div class="collection-hero__text rte">{{ section.settings.fallback_text }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection hero",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "Collection",
      "label": "Overline"
    },
    {
      "type": "richtext",
      "id": "fallback_text",
      "default": "<p>A composed edit of polished pieces designed to be discovered with ease and worn often.</p>",
      "label": "Fallback text"
    }
  ]
}
{% endschema %}
