{% paginate collection.products by section.settings.products_per_page %}
  <section class="section section--tight">
    <div class="section-shell collection-display">
      {% if collection.products_count > 0 %}
        <div class="collection-display__header">
          <div>
            <p class="collection-display__eyebrow">{{ section.settings.grid_overline }}</p>
            <p class="collection-display__intro">{{ section.settings.intro_text }}</p>
          </div>
          <p class="collection-display__meta">{{ 'collections.general.products_with_count' | t: count: collection.products_count }}</p>
        </div>

        <div class="product-grid product-grid--collection">
          {% for product in collection.products %}
            {% render 'product-card', product: product, image_ratio: section.settings.image_ratio, show_secondary: section.settings.show_secondary_image %}
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="collection-pagination">
            {% if paginate.previous %}
              <a class="button button--secondary" href="{{ paginate.previous.url }}">{{ 'general.pagination.previous' | t }}</a>
            {% endif %}
            {% if paginate.next %}
              <a class="button button--secondary" href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }}</a>
            {% endif %}
          </div>
        {% endif %}
      {% else %}
        <div class="panel">
          <p>{{ 'collections.general.empty' | t }}</p>
        </div>
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main collection grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "square",
      "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show second image on hover"
    },
    {
      "type": "text",
      "id": "grid_overline",
      "default": "Curated selection",
      "label": "Grid overline"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "default": "A quieter presentation gives each piece more room to feel deliberate, elevated, and desirable.",
      "label": "Intro text"
    }
  ]
}
{% endschema %}
