<section class="section section--tight">
  <div class="section-shell">
    <div class="section-heading">
      <p class="eyebrow">Your bag</p>
      <h1 class="section-heading__title">{{ 'cart.general.title' | t }}</h1>
    </div>

    {% if cart.item_count == 0 %}
      <div class="panel">
        <p>{{ 'cart.general.empty' | t }}</p>
        <div class="button-row" style="margin-top: 1rem;">
          <a class="button button--primary" href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_shopping' | t }}</a>
        </div>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page__grid">
        <div class="cart-items">
          {% for item in cart.items %}
            <article class="cart-item">
              <a class="cart-item__image" href="{{ item.url }}">
                {% if item.image %}
                  {{ item.image | image_url: width: 320 | image_tag: alt: item.product.title }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </a>
              <div class="cart-item__details">
                <div>
                  <h3>{{ item.product.title }}</h3>
                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-item__meta">{{ item.variant.title }}</p>
                  {% endunless %}
                </div>

                <div class="cart-item__row">
                  <div class="field" style="max-width: 120px;">
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                  </div>
                  <div class="price">{{ item.final_line_price | money }}</div>
                </div>

                <a class="link-inline" href="{{ item.url_to_remove }}">Remove {% render 'icon', icon: 'arrow' %}</a>
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="panel cart-summary">
          <div class="cart-summary__row">
            <span>{{ 'cart.general.subtotal' | t }}</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p class="cart-item__meta">{{ section.settings.note }}</p>
          <div class="button-row" style="margin-top: 1rem;">
            <button class="button button--secondary" type="submit">Update bag</button>
            <button class="button button--primary" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": [
    {
      "type": "textarea",
      "id": "note",
      "default": "Taxes and shipping are calculated at checkout. Keep this area concise and confidence-building.",
      "label": "Checkout note"
    }
  ]
}
{% endschema %}
