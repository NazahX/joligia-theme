{% paginate search.results by 12 %}
  <section class="section section--tight">
    <div class="section-shell">
      <div class="section-heading">
        <p class="eyebrow">{{ 'general.search.heading' | t }}</p>
        <h1 class="section-heading__title">
          {% if search.performed %}
            "{{ search.terms }}"
          {% else %}
            Search the collection
          {% endif %}
        </h1>
      </div>

      <form class="search-form" action="{{ routes.search_url }}" method="get" role="search">
        <div class="field">
          <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
        </div>
        <button class="button button--primary" type="submit">{{ 'general.search.submit' | t }}</button>
      </form>

      {% if search.performed %}
        <p class="collection-toolbar__meta" style="margin: 1.5rem 0;">{{ 'general.search.results_with_count' | t: count: search.results_count }}</p>

        {% if search.results_count > 0 %}
          <div class="product-grid" style="margin-top: 1rem;">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                {% render 'product-card', product: item, image_ratio: 'portrait', show_secondary: true %}
              {% else %}
                <article class="search-result">
                  <p class="eyebrow">{{ item.object_type }}</p>
                  <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                  {% if item.content != blank %}
                    <div class="rte">{{ item.content | strip_html | truncate: 160 }}</div>
                  {% endif %}
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="panel" style="margin-top: 1.5rem;">
            <p>{{ 'general.search.no_results' | t }}</p>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
