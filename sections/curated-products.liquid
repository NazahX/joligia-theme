{% liquid
  assign curated_collection = section.settings.collection
%}

<section class="section">
  <div class="section-shell">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.overline }}</p>
      <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: end; flex-wrap: wrap;">
        <div>
          <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
          {% if section.settings.text != blank %}
            <div class="section-heading__text rte">{{ section.settings.text }}</div>
          {% endif %}
        </div>
        {% if section.settings.link_label != blank %}
          <a class="link-inline" href="{{ section.settings.link | default: curated_collection.url | default: routes.all_products_collection_url }}">
            {{ section.settings.link_label }} {% render 'icon', icon: 'arrow' %}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="product-grid">
      {% if curated_collection != blank %}
        {% for product in curated_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product, image_ratio: 'portrait', show_secondary: true %}
        {% endfor %}
      {% else %}
        {% for index in (1..4) %}
          <article class="product-card">
            <div class="product-card__media product-card__media--portrait">
              {{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg product-card__image product-card__image--primary' }}
            </div>
            <div class="product-card__content">
              <h3 class="product-card__title">Best seller {{ index }}</h3>
              <div class="price">$245.00</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Curated products",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "Best sellers",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "The pieces customers return to first.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Highlight new arrivals, launch essentials, or proven favorites. Keep the edit tight and intentional.</p>",
      "label": "Text"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "link_label",
      "default": "Shop the edit",
      "label": "Link label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Curated products"
    }
  ]
}
{% endschema %}
