<section class="section section--tight">
  <div class="section-shell">
    {% render 'section-heading',
      overline: section.settings.overline,
      title: section.settings.heading,
      text: section.settings.text,
      alignment: 'center'
    %}

    <div class="testimonial-grid">
      {% for block in section.blocks %}
        <article class="testimonial panel" {{ block.shopify_attributes }}>
          <p class="testimonial__quote">"{{ block.settings.quote }}"</p>
          <div class="testimonial__meta">
            <strong>{{ block.settings.name }}</strong>
            {% if block.settings.meta != blank %}
              <p>{{ block.settings.meta }}</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "What customers say",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Loved for the edge, kept for the finish.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>The strongest proof for Joligia is simple: the pieces feel distinctive, wearable, and more elevated in person.</p>",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "default": "It has that darker, more dangerous energy I wanted, but it still feels polished and expensive in person.",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "default": "Alyssa M.",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "meta",
          "default": "Verified customer",
          "label": "Meta"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "It has that darker, more dangerous energy I wanted, but it still feels polished and expensive in person.",
            "name": "Alyssa M.",
            "meta": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The design is edgier than most jewellery I see online, but the finish is clean enough to wear every day.",
            "name": "Camille R.",
            "meta": "Collected two pieces"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The whole brand feels curated. Nothing looks mass-market, and the details have real personality.",
            "name": "Nadia T.",
            "meta": "Repeat customer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
