<section class="section">
  <div class="section-shell editorial-split__grid">
    <div class="editorial-split__media">
      {% render 'responsive-image',
        image: section.settings.image,
        class: 'editorial-split__image',
        sizes: '(min-width: 990px) 55vw, 100vw',
        width: 1600
      %}
    </div>

    <div class="editorial-split__content">
      {% render 'section-heading',
        overline: section.settings.overline,
        title: section.settings.heading,
        text: section.settings.text
      %}

      {% if section.settings.quote != blank %}
        <blockquote class="editorial-split__quote">{{ section.settings.quote }}</blockquote>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <div class="button-row">
          <a class="button button--secondary" href="{{ section.settings.button_link | default: routes.root_url }}">{{ section.settings.button_label }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial split",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "The world of Joligia",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Dark-hearted jewellery, refined into a cleaner line.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Joligia lives between romance and edge: softer silhouettes, sharper details, and styling that feels elevated instead of theatrical.</p>",
      "label": "Text"
    },
    {
      "type": "textarea",
      "id": "quote",
      "default": "The mood is subtle menace with polish: feminine, controlled, and impossible to mistake for a generic jewellery brand.",
      "label": "Quote"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "About Joligia",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Editorial split"
    }
  ]
}
{% endschema %}
