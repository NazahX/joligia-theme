{% liquid
  assign current_variant = product.selected_or_first_available_variant
%}

<section class="product-page">
  <div class="section-shell product-page__grid">
    <div class="product-gallery" data-product-gallery>
      <div class="product-gallery__thumbs">
        {% if product.media.size > 0 %}
          {% for media in product.media %}
            <button
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-gallery-thumb="{{ media.id }}"
            >
              {% if media.preview_image %}
                {{ media.preview_image | image_url: width: 180 | image_tag: alt: media.alt }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </button>
          {% endfor %}
        {% else %}
          <button class="product-gallery__thumb is-active" type="button" data-gallery-thumb="placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </button>
        {% endif %}
      </div>

      <div class="product-gallery__stage">
        {% if product.media.size > 0 %}
          {% for media in product.media %}
            <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide="{{ media.id }}">
              {% case media.media_type %}
                {% when 'image' %}
                  {{ media | image_url: width: 1800 | image_tag: alt: media.alt, loading: 'lazy' }}
                {% else %}
                  {{ media | media_tag }}
              {% endcase %}
            </div>
          {% endfor %}
        {% else %}
          <div class="product-gallery__slide is-active" data-gallery-slide="placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="product-details">
      <div class="product-details__header">
        {% if section.settings.eyebrow != blank %}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h1 class="product-details__title">{{ product.title }}</h1>
        {% render 'price', product_or_variant: current_variant %}
        {% if section.settings.subtitle != blank %}
          <p class="product-details__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if product.description != blank %}
          <div class="product-details__description rte">{{ product.description }}</div>
        {% endif %}
      </div>

      {% form 'product', product, class: 'product-form', data-product-form: '' %}
        {% if product.has_only_default_variant == false %}
          <div class="product-form__variant">
            <label for="VariantSelect-{{ section.id }}">Options</label>
            <div class="field">
              <select id="VariantSelect-{{ section.id }}" name="id">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }}{% unless variant.available %} - {{ 'products.product.sold_out' | t }}{% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% endif %}

        <div class="product-form__quantity-row">
          <div class="product-form__quantity">
            <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
            <div class="quantity-input" data-quantity-wrapper>
              <button type="button" data-quantity-button="decrease">{% render 'icon', icon: 'minus' %}</button>
              <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
              <button type="button" data-quantity-button="increase">{% render 'icon', icon: 'plus' %}</button>
            </div>
          </div>

          <div style="display:grid; align-items:end;">
            <button class="button button--primary" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
              {% if current_variant.available %}
                {{ 'products.product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
          </div>
        </div>

        {% if section.settings.show_dynamic_checkout %}
          {{ form | payment_button }}
        {% endif %}
      {% endform %}

      <ul class="trust-list">
        {% if section.settings.trust_item_1 != blank %}<li>{{ section.settings.trust_item_1 }}</li>{% endif %}
        {% if section.settings.trust_item_2 != blank %}<li>{{ section.settings.trust_item_2 }}</li>{% endif %}
        {% if section.settings.trust_item_3 != blank %}<li>{{ section.settings.trust_item_3 }}</li>{% endif %}
      </ul>

      <div class="accordion-group">
        {% for block in section.blocks %}
          <details class="accordion" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.heading }}</span>
              {% render 'icon', icon: 'plus' %}
            </summary>
            <div class="accordion__content rte">{{ block.settings.content }}</div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Curated piece",
      "label": "Eyebrow"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "A refined silhouette designed for daily wear, polished gifting, and confident layering.",
      "label": "Subtitle"
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "default": false,
      "label": "Show dynamic checkout button"
    },
    {
      "type": "text",
      "id": "trust_item_1",
      "default": "Complimentary insured shipping on every order.",
      "label": "Trust item 1"
    },
    {
      "type": "text",
      "id": "trust_item_2",
      "default": "Carefully packed for gifting or personal keeps.",
      "label": "Trust item 2"
    },
    {
      "type": "text",
      "id": "trust_item_3",
      "default": "Returns accepted according to your store policy.",
      "label": "Trust item 3"
    }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Materials",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "default": "<p>Outline your core materials, finishes, and any relevant gemstone details here.</p>",
          "label": "Content"
        }
      ]
    }
  ]
}
{% endschema %}
