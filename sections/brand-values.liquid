<section class="section section--tight">
  <div class="section-shell">
    {% render 'section-heading',
      overline: section.settings.overline,
      title: section.settings.heading,
      text: section.settings.text,
      alignment: 'center'
    %}

    <div class="value-grid">
      {% for block in section.blocks %}
        <div class="value-card" {{ block.shopify_attributes }}>
          <h3 class="value-card__title">{{ block.settings.title }}</h3>
          <p class="value-card__text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand values",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "The Joligia mood",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Dark-hearted detail, refined into something clean.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>The brand works when the attitude is visible but the execution stays calm, balanced, and precise.</p>",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Dark romance",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "The mood leans seductive and slightly dangerous, but the finish stays polished and controlled.",
          "label": "Text"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Brand values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Thoughtfully crafted",
            "text": "The mood leans seductive and slightly dangerous, but the finish stays polished and controlled."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Sharp femininity",
            "text": "Soft styling meets pointed detail so every piece feels feminine without turning sweet or predictable."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Clean finish",
            "text": "Even the bolder pieces stay refined through spacing, proportion, and a premium editorial presentation."
          }
        }
      ]
    }
  ]
}
{% endschema %}
