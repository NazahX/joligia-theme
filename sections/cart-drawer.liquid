<div class="cart-drawer" data-cart-drawer>
  <div class="drawer-backdrop" data-drawer-close></div>
  <aside class="cart-drawer__panel" aria-label="{{ 'cart.general.title' | t }}">
    <div data-cart-drawer-root>
      <div class="drawer-header">
        <h2 class="drawer-title">{{ 'cart.general.title' | t }}</h2>
        <button class="drawer-close" type="button" aria-label="{{ 'accessibility.close_cart' | t }}" data-drawer-close>
          {% render 'icon', icon: 'close' %}
        </button>
      </div>

      {% if cart.item_count == 0 %}
        <div class="panel cart-drawer__empty" style="margin-top: 1rem;">
          <p>{{ 'cart.general.empty' | t }}</p>
          <a class="button button--primary" href="{{ routes.all_products_collection_url }}" style="margin-top: 1rem;">
            {{ 'cart.general.continue_shopping' | t }}
          </a>
        </div>
      {% else %}
        <div class="cart-drawer__body">
          <div class="cart-items cart-items--drawer">
            {% for item in cart.items %}
              <article class="cart-item cart-item--drawer">
                <a class="cart-item__image" href="{{ item.url }}">
                  {% if item.image %}
                    {{ item.image | image_url: width: 320 | image_tag: alt: item.product.title }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </a>
                <div class="cart-item__details">
                  <div class="cart-item__top">
                    <div>
                      <h3 class="cart-item__title"><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                      {% unless item.product.has_only_default_variant %}
                        <p class="cart-item__meta">{{ item.variant.title }}</p>
                      {% endunless %}
                    </div>
                    <button class="cart-item__remove" type="button" data-cart-remove data-line="{{ forloop.index }}">
                      Remove
                    </button>
                  </div>

                  <div class="cart-item__bottom">
                    <div class="price">{{ item.final_line_price | money }}</div>
                    <div class="cart-item__controls">
                      <button
                        class="cart-item__qty-button"
                        type="button"
                        data-cart-quantity
                        data-line="{{ forloop.index }}"
                        data-quantity="{{ item.quantity | minus: 1 }}"
                      >
                        {% render 'icon', icon: 'minus' %}
                      </button>
                      <span class="cart-item__qty-value">{{ item.quantity }}</span>
                      <button
                        class="cart-item__qty-button"
                        type="button"
                        data-cart-quantity
                        data-line="{{ forloop.index }}"
                        data-quantity="{{ item.quantity | plus: 1 }}"
                      >
                        {% render 'icon', icon: 'plus' %}
                      </button>
                    </div>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>

        <div class="cart-drawer__footer">
          <div class="panel cart-summary cart-summary--drawer">
          <div class="cart-summary__row">
            <span>{{ 'cart.general.subtotal' | t }}</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p class="cart-summary__note">Shipping and taxes are calculated at checkout.</p>
          <div class="cart-summary__actions cart-summary__actions--drawer" style="margin-top: 1rem;">
            <form action="{{ routes.cart_url }}" method="post">
              <button class="button button--primary" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
            </form>
            <a class="button button--secondary" href="{{ routes.cart_url }}">{{ 'cart.general.view_cart' | t }}</a>
          </div>
        </div>
        </div>
      {% endif %}
    </div>
  </aside>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
