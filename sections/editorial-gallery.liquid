<section class="section section--tight">
  <div class="section-shell">
    {% render 'section-heading',
      overline: section.settings.overline,
      title: section.settings.heading,
      text: section.settings.text
    %}

    <div class="editorial-gallery__grid">
      {% for block in section.blocks %}
        <div class="editorial-gallery__item{% if block.settings.tall %} editorial-gallery__item--tall{% endif %}" {{ block.shopify_attributes }}>
          {% render 'responsive-image',
            image: block.settings.image,
            class: 'editorial-gallery__image',
            sizes: '(min-width: 990px) 33vw, 50vw',
            width: 1200
          %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial gallery",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "default": "After dark",
      "label": "Overline"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Let the imagery feel seductive, polished, and a little untouchable.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Replace these placeholders with campaign photography, detail crops, and studio imagery that pushes the darker Joligia mood.</p>",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "tall",
          "default": false,
          "label": "Tall image"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Editorial gallery",
      "blocks": [
        { "type": "image", "settings": { "tall": true } },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
