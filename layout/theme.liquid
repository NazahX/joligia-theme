<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- assign body_font_bold = settings.type_body_font | font_modify: 'weight', '700' -%}
    {%- assign heading_font_bold = settings.type_heading_font | font_modify: 'weight', '700' -%}
    {{ settings.type_body_font | font_face: font_display: 'swap' }}
    {{ body_font_bold | font_face: font_display: 'swap' }}
    {{ settings.type_heading_font | font_face: font_display: 'swap' }}
    {{ heading_font_bold | font_face: font_display: 'swap' }}

    <title>
      {{ page_title }}
      {%- if current_tags %} | {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} | Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-surface: {{ settings.color_surface }};
        --color-text: {{ settings.color_text }};
        --color-muted: {{ settings.color_muted }};
        --color-border: {{ settings.color_border }};
        --color-accent: {{ settings.color_accent }};
        --color-button-text: {{ settings.color_button_text }};
        --font-heading: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
        --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-size: {{ settings.base_font_size }}px;
        --logo-width: {{ settings.logo_width }}px;
      }
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
    <script>
      document.documentElement.classList.remove('no-js');
      window.theme = {
        routes: {
          cartAdd: '{{ routes.cart_add_url }}',
          cartChange: '{{ routes.cart_change_url }}',
          cartUrl: '{{ routes.cart_url }}',
          predictiveSearch: '{{ routes.predictive_search_url }}'
        },
        strings: {
          addToCart: {{ 'products.product.add_to_cart' | t | json }},
          soldOut: {{ 'products.product.sold_out' | t | json }},
          addedToCart: {{ 'products.product.added_to_cart' | t | json }},
          cartError: {{ 'cart.general.error' | t | json }}
        }
      };
    </script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.suffix | handle }}{% endif %}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    {% section 'announcement-bar' %}
    {% section 'site-header' %}
    {% section 'cart-drawer' %}

    <main id="MainContent" class="site-main" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'site-footer' %}
  </body>
</html>
